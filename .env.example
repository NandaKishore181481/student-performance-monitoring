# ==========================================
# EduInsight AI - Environment Configuration
# ==========================================

# --- SMTP Email Configuration ---
# To send actual emails, specify your SMTP provider credentials.
# For Gmail, you must use a Google App Password (not your main password).
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-google-app-password
SENDER_EMAIL=your-email@gmail.com
# Optional: Set to a carrier SMS gateway domain (e.g. tmomail.net, txt.att.net)
# to route SMS alerts completely for free via email. Leave empty to use Twilio.
CARRIER_GATEWAY_DOMAIN=

# --- Twilio SMS & WhatsApp Configuration ---
# To send actual SMS/WhatsApp alerts, specify your Twilio account details.
# Leaving these empty will keep the system in Simulation Mode.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Telegram Bot Configuration ---
# To send free alerts globally (including India) via Telegram:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
